# ── Discord ────────────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# The ID of the channel Alfred should watch (right-click channel → Copy Channel ID)
DISCORD_CHANNEL_ID=123456789012345678

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Jira ───────────────────────────────────────────────────────────────────────
# Your Jira Cloud base URL (no trailing slash)
JIRA_BASE_URL=https://yourcompany.atlassian.net

# The email address you use to log into Jira
JIRA_EMAIL=you@yourcompany.com

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# The short key for the Jira project where tickets should be created (e.g. ENG, OPS, PROJ)
JIRA_PROJECT_KEY=PROJ
